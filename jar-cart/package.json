{
  "name": "jar-cart",
  "displayName": "jar-cart",
  "description": "A zero-config JAR downloader for no-build Java projects.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jar-cart.add",
        "title": "JAR Cart: Search & Add to Cart"
      },
      {
        "command": "jar-cart.checkout",
        "title": "JAR Cart: Checkout (Install All)"
      },
      {
        "command": "jar-cart.clear",
        "title": "JAR Cart: Clear Cart"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "fs-extra": "^11.3.4"
  }
}
