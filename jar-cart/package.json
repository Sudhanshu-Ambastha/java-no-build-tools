{
  "name": "jar-cart-sa",
  "displayName": "JAR Cart 🛒 (SA)",
  "description": "Sovereign dependency manager for no-build Java projects. Lockfile support with granular control.",
  "version": "1.1.0",
  "publisher": "sudhanshuambastha",
  "license": "Apache-2.0",
  "icon": "images/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sudhanshu-Ambastha/java-no-build-tools",
    "directory": "jar-cart"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Programming Languages",
    "Education",
    "Other"
  ],
  "keywords": [
    "java",
    "jar",
    "maven",
    "dependencies",
    "no-build",
    "sovereign"
  ],
  "activationEvents": [
    "onLanguage:java",
    "workspaceContains:**/*.java"
  ],
  "extensionDependencies": [
    "redhat.java"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jar-cart.add",
        "title": "JAR Cart: Add to Cart"
      },
      {
        "command": "jar-cart.checkout",
        "title": "JAR Cart: Checkout (Sync to lib/)"
      },
      {
        "command": "jar-cart.sync",
        "title": "JAR Cart: Sync from jar-cart.json"
      },
      {
        "command": "jar-cart.view",
        "title": "JAR Cart: View Cart (Manifest)"
      },
      {
        "command": "jar-cart.purge",
        "title": "JAR Cart: Purge lib folder"
      }
    ],
    "keybindings": [
      {
        "command": "jar-cart.add",
        "key": "ctrl+shift+j",
        "mac": "cmd+shift+j",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "fs-extra": "^11.3.4",
    "xml2js": "^0.6.2"
  }
}
